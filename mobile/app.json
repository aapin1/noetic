{
  "expo": {
    "name": "mneme",
    "slug": "mneme",
    "owner": "aaronpintos-team",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "mneme",
    "splash": {
      "backgroundColor": "#F6F2E9",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.mneme.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Mneme uses your microphone so you can describe a capture in your own words."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6F2E9"
      },
      "package": "app.mneme.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Mneme uses your photos so you can save screenshots, book pages, and images to your memory.",
          "cameraPermission": "Mneme uses your camera so you can capture book pages and notes into your memory."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Mneme saves the cards you make to your Photos so you can share them.",
          "savePhotosPermission": "Mneme saves the cards you make to your Photos so you can share them.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          },
          "androidIntentFilters": [
            "text/*",
            "image/*"
          ]
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This lets Mneme show ads that are more relevant to you, which helps keep the app free."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3892528257283491~5018350937"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "40f91fac-13f5-44fa-b331-b3a85df60d6b"
      }
    }
  }
}
