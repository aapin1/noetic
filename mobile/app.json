{
  "expo": {
    "name": "NOETIC",
    "slug": "noetic",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "noetic",
    "splash": {
      "backgroundColor": "#F6F2E9",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.noetic.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F6F2E9"
      },
      "package": "app.noetic.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
