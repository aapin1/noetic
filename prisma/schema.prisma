generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pg_trgm]
}

enum Visibility {
  PUBLIC
  PRIVATE
  FOLLOWERS
}

enum MetadataStatus {
  COMPLETE
  MANUAL_REQUIRED
  MANUAL_ONLY
}

enum ActivityType {
  LOGGED_CONTENT
  REVIEWED_CONTENT
  RANKED_CONTENT
  SAVED_CONTENT
  FOLLOWED_USER
  LIKED_REVIEW
  COMMENTED
  SHARED_CONTENT
  PROFILE_UPDATED
}

enum NotificationType {
  NEW_FOLLOW
  NEW_LIKE
  NEW_COMMENT
  NEW_REPLY
  RANKING_UPDATED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum DeviceProvider {
  APNS
  FCM
  EXPO
}

enum CaptureKind {
  LINK
  TEXT
  QUOTE
  IMAGE
}

enum InsightType {
  PATTERN
  TRAJECTORY
  CONNECTION
  REINFORCES
  CONTRADICTS
  NOVELTY
  RECUR
}

enum MemoryEdgeType {
  RECURS
  REINFORCES
  CONTRADICTS
  EVOLVES_FROM
  RELATED
}

enum InsightStyle {
  DIRECT
  REFLECTIVE
  ANALYTICAL
}

enum CognitiveEventType {
  CAPTURED
  TOPIC_SHIFT
  CONTRADICTION_DETECTED
  PATTERN_DETECTED
  NOVELTY_DETECTED
}

enum PositionStatus {
  ACTIVE
  REVISED
  ABANDONED
}

enum UserPlan {
  FREE
  PLUS
}

enum SocraticRole {
  USER
  COMPANION
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  passwordHash        String?
  plan                UserPlan           @default(FREE)
  tasteProfileVersion Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  userTopics          UserTopic[]
  logs                LogEntry[]
  reviews             Review[]
  rankingLists        RankingList[]
  followings          Follow[]           @relation("Follower")
  followers           Follow[]           @relation("Following")
  likes               Like[]
  saves               Save[]
  comments            Comment[]
  shareEvents         ShareEvent[]
  activityEvents      ActivityEvent[]    @relation("ActivityActor")
  targetedActivities  ActivityEvent[]    @relation("ActivityTargetUser")
  notifications       Notification[]     @relation("NotificationRecipient")
  triggeredNotifications Notification[]  @relation("NotificationActor")
  deviceTokens        DeviceToken[]
  comparisonCacheLeft ComparisonCache[]  @relation("ComparisonLeft")
  comparisonCacheRight ComparisonCache[] @relation("ComparisonRight")
  capturedItems       CapturedItem[]
  insights            Insight[]
  memoryEdges         MemoryEdge[]
  cognitiveEvents     CognitiveEvent[]
  preference          UserPreference?
  positions           UserPosition[]
  socraticThreads     SocraticThread[]
  companionThread     CompanionThread?
  intelligenceCache   IntelligenceCache?
  terrainCache        TerrainCache?
  usageCounters       UsageCounter[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  handle          String   @unique
  displayName     String
  bio             String?
  publicNotes     String?
  identitySummary String?
  avatarUrl       String?
  isOnboarded     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([handle])
  // Trigram indexes back the substring/fuzzy branch of user search. Postgres
  // cannot use a plain btree for `ILIKE '%q%'`, so without these every
  // keystroke sequentially scans every profile.
  @@index([handle(ops: raw("gin_trgm_ops"))], map: "Profile_handle_trgm_idx", type: Gin)
  @@index([displayName(ops: raw("gin_trgm_ops"))], map: "Profile_displayName_trgm_idx", type: Gin)
}

model Topic {
  id          String             @id @default(cuid())
  name        String             @unique
  slug        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userTopics  UserTopic[]
  contentTags ContentItemTopic[]
  logTags     LogEntryTopic[]
  capturedTags CapturedItemTopic[]
  positions        UserPosition[]
  socraticThreads  SocraticThread[]

  @@index([slug])
}

model UserTopic {
  id               String   @id @default(cuid())
  userId           String
  topicId          String
  weight           Float    @default(0)
  lastInteractedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic            Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, weight])
}

model ContentSource {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  domain      String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contentItems ContentItem[]
}

model ContentType {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contentItems ContentItem[]
}

model ContentItem {
  id             String            @id @default(cuid())
  title          String
  description    String?
  bodyText       String?
  /// Where bodyText came from: transcript | body | jsonld | reddit | description | user
  bodySource     String?
  canonicalUrl   String?           @unique
  originalUrl    String?
  siteName       String?
  imageUrl       String?
  authorName     String?
  publishedAt    DateTime?
  metadataStatus MetadataStatus    @default(COMPLETE)
  sourceId       String?
  contentTypeId  String?
  manualFields   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  source         ContentSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  contentType    ContentType?      @relation(fields: [contentTypeId], references: [id], onDelete: SetNull)
  topics         ContentItemTopic[]
  logs           LogEntry[]
  rankingItems   RankedItem[]
  saves          Save[]
  shareEvents    ShareEvent[]
  activityEvents ActivityEvent[]
  captures       CapturedItem[]

  @@index([title])
  @@index([canonicalUrl])
}

model ContentItemTopic {
  contentItemId String
  topicId       String
  createdAt     DateTime    @default(now())
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  topic         Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([contentItemId, topicId])
  @@index([topicId])
}

model LogEntry {
  id           String         @id @default(cuid())
  userId       String
  contentItemId String
  rating       Int?
  annotation   String?
  visibility   Visibility     @default(PUBLIC)
  loggedAt     DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem  ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  review       Review?
  topics       LogEntryTopic[]
  activityEvents ActivityEvent[]

  @@unique([userId, contentItemId])
  @@index([userId, loggedAt])
  @@index([visibility, loggedAt])
}

model LogEntryTopic {
  logEntryId String
  topicId    String
  createdAt  DateTime @default(now())
  logEntry   LogEntry  @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  topic      Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([logEntryId, topicId])
  @@index([topicId])
}

model Review {
  id           String         @id @default(cuid())
  logEntryId    String         @unique
  authorId      String
  content       String
  visibility    Visibility     @default(PUBLIC)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  logEntry      LogEntry       @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  shareEvents   ShareEvent[]
  activityEvents ActivityEvent[]

  @@index([authorId, createdAt])
  @@index([visibility, createdAt])
}

model RankingList {
  id           String         @id @default(cuid())
  userId        String
  title         String
  description   String?
  visibility    Visibility     @default(PUBLIC)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         RankedItem[]
  activityEvents ActivityEvent[]

  @@unique([userId, title])
  @@index([userId, updatedAt])
  @@index([visibility, updatedAt])
}

model RankedItem {
  id            String        @id @default(cuid())
  rankingListId String
  contentItemId String
  position      Int
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rankingList   RankingList   @relation(fields: [rankingListId], references: [id], onDelete: Cascade)
  contentItem   ContentItem   @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([rankingListId, contentItemId])
  @@unique([rankingListId, position])
  @@index([contentItemId])
}

model Follow {
  id          String    @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime  @default(now())
  follower    User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  activityEvents ActivityEvent[]

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  userId     String
  reviewId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId, createdAt])
}

model Save {
  id           String      @id @default(cuid())
  userId        String
  contentItemId String
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([userId, contentItemId])
  @@index([contentItemId, createdAt])
}

model Comment {
  id            String         @id @default(cuid())
  authorId       String
  reviewId       String
  parentId       String?
  content        String
  visibility     Visibility     @default(PUBLIC)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  review         Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent         Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]      @relation("CommentReplies")
  activityEvents ActivityEvent[]

  @@index([reviewId, createdAt])
  @@index([parentId])
}

model ShareEvent {
  id           String       @id @default(cuid())
  userId        String
  contentItemId String
  reviewId      String?
  platform      String
  deepLink      String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem   ContentItem  @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  review        Review?      @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  activityEvents ActivityEvent[]

  @@index([contentItemId, createdAt])
}

model ComparisonCache {
  id           String   @id @default(cuid())
  comparisonKey String  @unique
  leftUserId   String
  rightUserId  String
  leftVersion  Int
  rightVersion Int
  score        Float
  explanation  Json
  computedAt   DateTime @default(now())
  leftUser     User     @relation("ComparisonLeft", fields: [leftUserId], references: [id], onDelete: Cascade)
  rightUser    User     @relation("ComparisonRight", fields: [rightUserId], references: [id], onDelete: Cascade)

  @@index([leftUserId, rightUserId])
}

model Notification {
  id          String             @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  title       String
  body        String
  deepLink    String
  payload     Json
  status      NotificationStatus @default(PENDING)
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime           @default(now())
  recipient   User               @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?              @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([status, createdAt])
}

model ActivityEvent {
  id            String       @id @default(cuid())
  actorId        String
  type           ActivityType
  contentItemId  String?
  logEntryId     String?
  reviewId       String?
  rankingListId  String?
  followId       String?
  commentId      String?
  shareEventId   String?
  targetUserId   String?
  visibility     Visibility   @default(PUBLIC)
  weight         Float
  metadata       Json?
  occurredAt     DateTime     @default(now())
  actor          User         @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  contentItem    ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  logEntry       LogEntry?    @relation(fields: [logEntryId], references: [id], onDelete: SetNull)
  review         Review?      @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  rankingList    RankingList? @relation(fields: [rankingListId], references: [id], onDelete: SetNull)
  follow         Follow?      @relation(fields: [followId], references: [id], onDelete: SetNull)
  comment        Comment?     @relation(fields: [commentId], references: [id], onDelete: SetNull)
  shareEvent     ShareEvent?  @relation(fields: [shareEventId], references: [id], onDelete: SetNull)
  targetUser     User?        @relation("ActivityTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId, occurredAt])
  @@index([contentItemId, occurredAt])
  @@index([visibility, occurredAt])
}

model DeviceToken {
  id         String         @id @default(cuid())
  userId      String
  platform    DevicePlatform
  provider    DeviceProvider
  token       String
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, token])
  @@index([userId, isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CapturedItem {
  id              String              @id @default(cuid())
  userId          String
  kind            CaptureKind
  contentItemId   String?
  rawText         String?             @db.Text
  caption         String?             @db.Text
  mediaUrl        String?
  reaction        String?             @db.Text
  /// The user's own account of what the content was about (capture fail-safe / post-hoc correction). Treated as ground truth by the pipeline.
  userContext     String?             @db.Text
  /// User-chosen display title. Cosmetic only — never fed to the pipeline; wins over the content title on every read surface.
  userTitle       String?
  summary         String?             @db.Text
  keyIdea         String?             @db.Text
  terms           Json
  embedding       Float[]             @default([])
  mapX            Float?
  mapY            Float?
  capturedAt      DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem     ContentItem?        @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  insights        Insight[]
  edgesFrom       MemoryEdge[]        @relation("EdgesFrom")
  edgesTo         MemoryEdge[]        @relation("EdgesTo")
  cognitiveEvents CognitiveEvent[]
  topics          CapturedItemTopic[]
  positionChallenges PositionChallenge[]

  @@index([userId, capturedAt])
  @@index([userId, kind])
}

model CapturedItemTopic {
  capturedItemId String
  topicId        String
  weight         Float        @default(1)
  capturedItem   CapturedItem @relation(fields: [capturedItemId], references: [id], onDelete: Cascade)
  topic          Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([capturedItemId, topicId])
  @@index([topicId])
}

model Insight {
  id             String       @id @default(cuid())
  userId         String
  capturedItemId String
  type           InsightType
  headline       String       @db.Text
  body           String       @db.Text
  evidence       Json
  strength       Float
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  capturedItem   CapturedItem @relation(fields: [capturedItemId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([capturedItemId])
}

model MemoryEdge {
  id         String         @id @default(cuid())
  userId     String
  fromItemId String
  toItemId   String
  type       MemoryEdgeType
  weight     Float
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromItem   CapturedItem   @relation("EdgesFrom", fields: [fromItemId], references: [id], onDelete: Cascade)
  toItem     CapturedItem   @relation("EdgesTo", fields: [toItemId], references: [id], onDelete: Cascade)

  @@unique([fromItemId, toItemId, type])
  @@index([userId, createdAt])
  @@index([toItemId])
}

model CognitiveEvent {
  id             String              @id @default(cuid())
  userId         String
  capturedItemId String?
  type           CognitiveEventType
  payload        Json
  occurredAt     DateTime            @default(now())
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  capturedItem   CapturedItem?       @relation(fields: [capturedItemId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
}

model UserPreference {
  id           String       @id @default(cuid())
  userId       String       @unique
  insightStyle InsightStyle @default(DIRECT)
  preferences  Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPosition {
  id                     String              @id @default(cuid())
  userId                 String
  topicId                String
  statement              String              @db.Text
  captureCountAtCreation Int                 @default(0)
  status                 PositionStatus      @default(ACTIVE)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic                  Topic               @relation(fields: [topicId], references: [id], onDelete: Cascade)
  challenges             PositionChallenge[]

  @@unique([userId, topicId])
  @@index([userId, createdAt])
}

model PositionChallenge {
  id             String       @id @default(cuid())
  positionId     String
  capturedItemId String?
  tension        String       @db.Text
  acknowledged   Boolean      @default(false)
  revised        Boolean      @default(false)
  revision       String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  position       UserPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  capturedItem   CapturedItem? @relation(fields: [capturedItemId], references: [id], onDelete: SetNull)

  @@unique([positionId, capturedItemId])
  @@index([positionId, createdAt])
  @@index([capturedItemId])
}

model SocraticThread {
  id        String            @id @default(cuid())
  userId    String
  topicId   String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic             @relation(fields: [topicId], references: [id], onDelete: Cascade)
  messages  SocraticMessage[]

  @@unique([userId, topicId])
  @@index([userId, updatedAt])
}

model SocraticMessage {
  id        String         @id @default(cuid())
  threadId  String
  role      SocraticRole
  content   String         @db.Text
  createdAt DateTime       @default(now())
  thread    SocraticThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model CompanionThread {
  id        String             @id @default(cuid())
  userId    String             @unique
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  CompanionMessage[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model CompanionMessage {
  id        String          @id @default(cuid())
  threadId  String
  thread    CompanionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      SocraticRole
  content   String          @db.Text
  createdAt DateTime        @default(now())

  @@index([threadId, createdAt])
}

/// Cached LLM-derived Mind intelligence (contradictions, syntheses,
/// convergence). Keyed on the tasteProfileVersion it was computed at, so it
/// regenerates only when the memory graph actually changes — not on every
/// Mind open. Time-sensitive parts (dormant threads) are always recomputed.
model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  /// Metered action: social_video_transcript | image_describe | companion_message | whisper_seconds
  kind      String
  /// "2026-07" for monthly kinds, "2026-07-11" for daily kinds
  period    String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, period])
}

model IntelligenceCache {
  userId    String   @id
  version   Int
  payload   Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Cached "terrain" self-portrait. `version` is a capture-count bucket (floor(count / 25)),
/// so the payload — including its one LLM narrative — regenerates only every ~25 captures.
model TerrainCache {
  userId    String   @id
  version   Int
  payload   Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
