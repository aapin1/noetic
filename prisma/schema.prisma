generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Visibility {
  PUBLIC
  PRIVATE
  FOLLOWERS
}

enum MetadataStatus {
  COMPLETE
  MANUAL_REQUIRED
  MANUAL_ONLY
}

enum ActivityType {
  LOGGED_CONTENT
  REVIEWED_CONTENT
  RANKED_CONTENT
  SAVED_CONTENT
  FOLLOWED_USER
  LIKED_REVIEW
  COMMENTED
  SHARED_CONTENT
  PROFILE_UPDATED
}

enum NotificationType {
  NEW_FOLLOW
  NEW_LIKE
  NEW_COMMENT
  NEW_REPLY
  RANKING_UPDATED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum DeviceProvider {
  APNS
  FCM
  EXPO
}

model User {
  id                  String             @id @default(cuid())
  email               String             @unique
  emailVerified       DateTime?
  name                String?
  image               String?
  passwordHash        String?
  tasteProfileVersion Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  accounts            Account[]
  sessions            Session[]
  profile             Profile?
  userTopics          UserTopic[]
  logs                LogEntry[]
  reviews             Review[]
  rankingLists        RankingList[]
  followings          Follow[]           @relation("Follower")
  followers           Follow[]           @relation("Following")
  likes               Like[]
  saves               Save[]
  comments            Comment[]
  shareEvents         ShareEvent[]
  activityEvents      ActivityEvent[]    @relation("ActivityActor")
  targetedActivities  ActivityEvent[]    @relation("ActivityTargetUser")
  notifications       Notification[]     @relation("NotificationRecipient")
  triggeredNotifications Notification[]  @relation("NotificationActor")
  deviceTokens        DeviceToken[]
  comparisonCacheLeft ComparisonCache[]  @relation("ComparisonLeft")
  comparisonCacheRight ComparisonCache[] @relation("ComparisonRight")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  handle          String   @unique
  displayName     String
  bio             String?
  publicNotes     String?
  identitySummary String?
  avatarUrl       String?
  isOnboarded     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([handle])
}

model Topic {
  id          String             @id @default(cuid())
  name        String             @unique
  slug        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  userTopics  UserTopic[]
  contentTags ContentItemTopic[]
  logTags     LogEntryTopic[]

  @@index([slug])
}

model UserTopic {
  id               String   @id @default(cuid())
  userId           String
  topicId          String
  weight           Float    @default(0)
  lastInteractedAt DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic            Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, weight])
}

model ContentSource {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  domain      String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contentItems ContentItem[]
}

model ContentType {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  contentItems ContentItem[]
}

model ContentItem {
  id             String            @id @default(cuid())
  title          String
  description    String?
  canonicalUrl   String?           @unique
  originalUrl    String?
  siteName       String?
  imageUrl       String?
  authorName     String?
  publishedAt    DateTime?
  metadataStatus MetadataStatus    @default(COMPLETE)
  sourceId       String?
  contentTypeId  String?
  manualFields   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  source         ContentSource?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  contentType    ContentType?      @relation(fields: [contentTypeId], references: [id], onDelete: SetNull)
  topics         ContentItemTopic[]
  logs           LogEntry[]
  rankingItems   RankedItem[]
  saves          Save[]
  shareEvents    ShareEvent[]
  activityEvents ActivityEvent[]

  @@index([title])
  @@index([canonicalUrl])
}

model ContentItemTopic {
  contentItemId String
  topicId       String
  createdAt     DateTime    @default(now())
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  topic         Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([contentItemId, topicId])
  @@index([topicId])
}

model LogEntry {
  id           String         @id @default(cuid())
  userId       String
  contentItemId String
  rating       Int?
  annotation   String?
  visibility   Visibility     @default(PUBLIC)
  loggedAt     DateTime       @default(now())
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem  ContentItem    @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  review       Review?
  topics       LogEntryTopic[]
  activityEvents ActivityEvent[]

  @@unique([userId, contentItemId])
  @@index([userId, loggedAt])
  @@index([visibility, loggedAt])
}

model LogEntryTopic {
  logEntryId String
  topicId    String
  createdAt  DateTime @default(now())
  logEntry   LogEntry  @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  topic      Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([logEntryId, topicId])
  @@index([topicId])
}

model Review {
  id           String         @id @default(cuid())
  logEntryId    String         @unique
  authorId      String
  content       String
  visibility    Visibility     @default(PUBLIC)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  logEntry      LogEntry       @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  shareEvents   ShareEvent[]
  activityEvents ActivityEvent[]

  @@index([authorId, createdAt])
  @@index([visibility, createdAt])
}

model RankingList {
  id           String         @id @default(cuid())
  userId        String
  title         String
  description   String?
  visibility    Visibility     @default(PUBLIC)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         RankedItem[]
  activityEvents ActivityEvent[]

  @@unique([userId, title])
  @@index([userId, updatedAt])
  @@index([visibility, updatedAt])
}

model RankedItem {
  id            String        @id @default(cuid())
  rankingListId String
  contentItemId String
  position      Int
  note          String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rankingList   RankingList   @relation(fields: [rankingListId], references: [id], onDelete: Cascade)
  contentItem   ContentItem   @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([rankingListId, contentItemId])
  @@unique([rankingListId, position])
  @@index([contentItemId])
}

model Follow {
  id          String    @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime  @default(now())
  follower    User      @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User      @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  activityEvents ActivityEvent[]

  @@unique([followerId, followingId])
  @@index([followingId, createdAt])
}

model Like {
  id        String   @id @default(cuid())
  userId     String
  reviewId   String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@index([reviewId, createdAt])
}

model Save {
  id           String      @id @default(cuid())
  userId        String
  contentItemId String
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  @@unique([userId, contentItemId])
  @@index([contentItemId, createdAt])
}

model Comment {
  id            String         @id @default(cuid())
  authorId       String
  reviewId       String
  parentId       String?
  content        String
  visibility     Visibility     @default(PUBLIC)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  author         User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  review         Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  parent         Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies        Comment[]      @relation("CommentReplies")
  activityEvents ActivityEvent[]

  @@index([reviewId, createdAt])
  @@index([parentId])
}

model ShareEvent {
  id           String       @id @default(cuid())
  userId        String
  contentItemId String
  reviewId      String?
  platform      String
  deepLink      String?
  metadata      Json?
  createdAt     DateTime     @default(now())
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentItem   ContentItem  @relation(fields: [contentItemId], references: [id], onDelete: Cascade)
  review        Review?      @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  activityEvents ActivityEvent[]

  @@index([contentItemId, createdAt])
}

model ComparisonCache {
  id           String   @id @default(cuid())
  comparisonKey String  @unique
  leftUserId   String
  rightUserId  String
  leftVersion  Int
  rightVersion Int
  score        Float
  explanation  Json
  computedAt   DateTime @default(now())
  leftUser     User     @relation("ComparisonLeft", fields: [leftUserId], references: [id], onDelete: Cascade)
  rightUser    User     @relation("ComparisonRight", fields: [rightUserId], references: [id], onDelete: Cascade)

  @@index([leftUserId, rightUserId])
}

model Notification {
  id          String             @id @default(cuid())
  recipientId String
  actorId     String?
  type        NotificationType
  title       String
  body        String
  deepLink    String
  payload     Json
  status      NotificationStatus @default(PENDING)
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime           @default(now())
  recipient   User               @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User?              @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([recipientId, createdAt])
  @@index([status, createdAt])
}

model ActivityEvent {
  id            String       @id @default(cuid())
  actorId        String
  type           ActivityType
  contentItemId  String?
  logEntryId     String?
  reviewId       String?
  rankingListId  String?
  followId       String?
  commentId      String?
  shareEventId   String?
  targetUserId   String?
  visibility     Visibility   @default(PUBLIC)
  weight         Float
  metadata       Json?
  occurredAt     DateTime     @default(now())
  actor          User         @relation("ActivityActor", fields: [actorId], references: [id], onDelete: Cascade)
  contentItem    ContentItem? @relation(fields: [contentItemId], references: [id], onDelete: SetNull)
  logEntry       LogEntry?    @relation(fields: [logEntryId], references: [id], onDelete: SetNull)
  review         Review?      @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  rankingList    RankingList? @relation(fields: [rankingListId], references: [id], onDelete: SetNull)
  follow         Follow?      @relation(fields: [followId], references: [id], onDelete: SetNull)
  comment        Comment?     @relation(fields: [commentId], references: [id], onDelete: SetNull)
  shareEvent     ShareEvent?  @relation(fields: [shareEventId], references: [id], onDelete: SetNull)
  targetUser     User?        @relation("ActivityTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorId, occurredAt])
  @@index([contentItemId, occurredAt])
  @@index([visibility, occurredAt])
}

model DeviceToken {
  id         String         @id @default(cuid())
  userId      String
  platform    DevicePlatform
  provider    DeviceProvider
  token       String
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, token])
  @@index([userId, isActive])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
